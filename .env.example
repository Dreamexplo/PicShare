# PicShare environment variables
# Copy this file as .env.local and fill in your values

# Supabase database + storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_STORAGE_BUCKET=picshare

# Admin password for dashboard (optional)
# If set, users must enter this password to create/manage albums
# Leave unset (or remove) to allow open access
ADMIN_PASSWORD=your-admin-password-here